---
type Props = {
  activeLanguage: "en" | "zh";
  enUrl?: string;
  zhUrl?: string;
};

const { activeLanguage, enUrl, zhUrl } = Astro.props;
---

{
  enUrl && zhUrl && (
    <nav class="view-filter language-switch" aria-label="Article language">
      <div>
        <a href={enUrl} hreflang="en" lang="en" aria-current={activeLanguage === "en" ? "page" : undefined}>
          EN
        </a>
        <a href={zhUrl} hreflang="zh" lang="zh" aria-current={activeLanguage === "zh" ? "page" : undefined}>
          中文
        </a>
      </div>
    </nav>
  )
}
