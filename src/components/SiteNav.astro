---
import ContentViewFilter from "@/components/ContentViewFilter.astro";
import MobileMenuIsland from "@/components/MobileMenuIsland";
import SearchForm from "@/components/SearchForm.astro";

type ViewKey = "all" | "en" | "zh";

type Props = {
  showContentView?: boolean;
  initialView: ViewKey;
  hrefs: Record<ViewKey, string>;
};

const { showContentView = true, initialView, hrefs } = Astro.props;

const scopePrefix = initialView === "all" ? "" : `/${initialView}`;
const links = [
  { href: `${scopePrefix}/writing/`, label: "Writing" },
  { href: `${scopePrefix}/projects/`, label: "Projects" },
  { href: `${scopePrefix}/about/`, label: "About" }
];
const homeUrl = `${scopePrefix}/`;
---

<header class="mobile-header">
  <a class="site-brand" href={homeUrl}>PROMISE XU</a>
  <MobileMenuIsland
    client:only="react"
    links={links}
    showContentView={showContentView}
    initialView={initialView}
    hrefs={hrefs}
  />
</header>

<aside class="site-rail" aria-label="Site navigation">
  <div class="site-rail__top">
    <a class="site-brand site-brand--rail" href={homeUrl}>
      <span>PROMISE</span>
      <span>XU</span>
    </a>
    <nav class="site-rail__nav" aria-label="Primary navigation">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <SearchForm id="rail-site-search" />
  </div>
  {showContentView && (
    <div class="site-rail__bottom">
      <ContentViewFilter selected={initialView} hrefs={hrefs} />
    </div>
  )}
</aside>
