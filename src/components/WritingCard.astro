---
import { getWritingUrl, type WritingEntry } from "@/lib/content";
import { stripHtml } from "@/lib/seo";

type Props = {
  entry: WritingEntry;
  headingLevel?: "h2" | "h3";
  variant?: "lead" | "tile" | "row";
  showFeaturedTag?: boolean;
  alternateUrl?: string;
  alternateLabel?: string;
  homepage?: boolean;
};

const {
  entry,
  headingLevel = "h2",
  variant = "row",
  showFeaturedTag = true,
  alternateUrl,
  alternateLabel,
  homepage = false
} = Astro.props;
const Heading = headingLevel;
const date = entry.data.date.toISOString().slice(0, 10);
const dateLabel =
  entry.data.date.getUTCFullYear() === new Date().getUTCFullYear()
    ? entry.data.date.toLocaleDateString("en", { month: "short", day: "numeric", timeZone: "UTC" })
    : String(entry.data.date.getUTCFullYear());
const showImage = variant !== "row" && entry.data.featureImage;
const plainTitle = stripHtml(entry.data.title);
---

<article
  class:list={["writing-row", `writing-row--${variant}`, showImage && "writing-row--with-image"]}
  data-lang={entry.data.lang}
  data-category={entry.data.category}
>
  {showImage && (
    <a class="writing-row__media" href={getWritingUrl(entry)} aria-label={`Read ${plainTitle}`}>
      <img src={entry.data.featureImage} alt="" loading={variant === "lead" ? "eager" : "lazy"} />
    </a>
  )}
  <div class="writing-row__body">
    {homepage ? (
      <>
        <div class="writing-row__title-line">
          <Heading><a href={getWritingUrl(entry)} set:html={entry.data.title}></a></Heading>
          <time class="writing-row__meta" datetime={date}>{dateLabel}</time>
        </div>
        {(showFeaturedTag && entry.data.featured || alternateUrl && alternateLabel) && (
          <p class="writing-row__flags">
            {showFeaturedTag && entry.data.featured && <span class="tag">Featured</span>}
            {alternateUrl && alternateLabel && (
              <span data-view-only="all">
                {showFeaturedTag && entry.data.featured && <> &middot; </>}
                <a class="translation-link" href={alternateUrl} hreflang="zh">{alternateLabel}</a>
              </span>
            )}
          </p>
        )}
      </>
    ) : (
      <>
        <Heading><a href={getWritingUrl(entry)} set:html={entry.data.title}></a></Heading>
        <p class="writing-row__meta">
          {showFeaturedTag && entry.data.featured && <><span class="tag">Featured</span> &middot; </>}
          {entry.data.category} &middot; <time datetime={date}>{date}</time>
          {alternateUrl && alternateLabel && (
            <span data-view-only="all"> &middot; <a class="translation-link" href={alternateUrl} hreflang="zh">{alternateLabel}</a></span>
          )}
        </p>
      </>
    )}
  </div>
</article>
