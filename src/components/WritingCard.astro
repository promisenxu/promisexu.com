---
import { getWritingUrl, type WritingEntry } from "@/lib/content";

type Props = {
  entry: WritingEntry;
  headingLevel?: "h2" | "h3";
  variant?: "lead" | "tile" | "row";
  showFeaturedTag?: boolean;
};

const { entry, headingLevel = "h2", variant = "row", showFeaturedTag = true } = Astro.props;
const Heading = headingLevel;
const date = entry.data.date.toISOString().slice(0, 10);
const showImage = variant !== "row" && entry.data.featureImage;
---

<article
  class:list={["writing-row", `writing-row--${variant}`, showImage && "writing-row--with-image"]}
  data-lang={entry.data.lang}
  data-category={entry.data.category}
>
  {showImage && (
    <a class="writing-row__media" href={getWritingUrl(entry)} aria-label={`Read ${entry.data.title}`}>
      <img src={entry.data.featureImage} alt="" loading={variant === "lead" ? "eager" : "lazy"} />
    </a>
  )}
  <div class="writing-row__label">
    {showFeaturedTag && entry.data.featured && <span class="tag">Featured</span>}
  </div>
  <div class="writing-row__body">
    <Heading><a href={getWritingUrl(entry)}>{entry.data.title}</a></Heading>
    <p class="writing-row__description">{entry.data.description}</p>
    <p class="writing-row__meta">{entry.data.category} &middot; <time datetime={date}>{date}</time></p>
  </div>
</article>
