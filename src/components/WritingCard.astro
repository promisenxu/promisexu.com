---
import { getWritingUrl, type WritingEntry } from "@/lib/content";

type Props = {
  entry: WritingEntry;
};

const { entry } = Astro.props;
const date = entry.data.date.toISOString().slice(0, 10);
const languageLabel = entry.data.lang === "zh" ? "中文" : "English";
---

<article class="writing-card" data-lang={entry.data.lang} data-category={entry.data.category}>
  <p class="writing-card__meta">{languageLabel} &middot; {entry.data.category}</p>
  <h2><a href={getWritingUrl(entry)}>{entry.data.title}</a></h2>
  <p class="writing-card__description">{entry.data.description}</p>
  <time datetime={date}>{date}</time>
</article>

<style>
  .writing-card {
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .writing-card h2 {
    margin: 0 0 8px;
    font-size: clamp(1.35rem, 2vw, 2rem);
    line-height: 1.2;
  }

  .writing-card p {
    margin: 0 0 12px;
  }

  .writing-card__meta,
  .writing-card time {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .writing-card__description {
    color: var(--color-muted);
    line-height: 1.6;
  }
</style>
