---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LanguageSwitch from "@/components/LanguageSwitch.astro";
import { articleJsonLd, buildSeo } from "@/lib/seo";
import { getWritingCounterpart, getWritingUrl, type WritingEntry } from "@/lib/content";
import { site } from "@/lib/site";

type Props = {
  entry: WritingEntry;
};

const { entry } = Astro.props;
const coAuthors = entry.data.coAuthors ?? [];
const url = getWritingUrl(entry);
const description = entry.data.seoDescription ?? site.description;
const seo = buildSeo({
  title: entry.data.title,
  description,
  path: url,
  canonical: entry.data.canonicalUrl,
  type: "article"
});
const counterpart = await getWritingCounterpart(entry);
const counterpartCanonical = counterpart && buildSeo({
  title: counterpart.data.title,
  description: counterpart.data.seoDescription ?? site.description,
  path: getWritingUrl(counterpart),
  canonical: counterpart.data.canonicalUrl,
  type: "article"
}).canonical;
const enUrl = entry.data.lang === "en" ? url : counterpart && getWritingUrl(counterpart);
const zhUrl = entry.data.lang === "zh" ? url : counterpart && getWritingUrl(counterpart);
const alternates = counterpart
  ? [
      { lang: "en" as const, href: entry.data.lang === "en" ? seo.canonical : counterpartCanonical! },
      { lang: "zh" as const, href: entry.data.lang === "zh" ? seo.canonical : counterpartCanonical! }
    ]
  : [];
const publishedDate = entry.data.date.toISOString().slice(0, 10);
const updatedDate = entry.data.updated?.toISOString().slice(0, 10);
const dateFormat = { month: "short", day: "numeric", year: "numeric", timeZone: "UTC" } as const;
const publishedDateLabel = entry.data.date.toLocaleDateString("en", dateFormat);
const updatedDateLabel = entry.data.updated?.toLocaleDateString("en", dateFormat);
const jsonLd = [
  articleJsonLd({
    title: entry.data.title,
    description,
    url: seo.canonical,
    datePublished: entry.data.date,
    dateModified: entry.data.updated,
    lang: entry.data.lang,
    coAuthors
  })
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  author={site.author}
  alternates={alternates}
  lang={entry.data.lang}
  image={seo.image}
  type="article"
  jsonLd={jsonLd}
  showContentView={false}
>
  <main class="article-shell">
    <article lang={entry.data.lang}>
      <header class="article-header">
        <p class="eyebrow">{entry.data.category}</p>
        <h1 set:html={entry.data.title}></h1>
        {
          coAuthors.length > 0 && (
            <p class="co-authors meta">
              {entry.data.lang === "zh" ? "合著者：" : "Co-Authored by: "}
              {coAuthors.map((author, index) => (
                <>
                  {index > 0 && (entry.data.lang === "zh" ? "、" : ", ")}
                  {author.link ? <a href={author.link} target="_blank">{author.name}</a> : author.name}
                </>
              ))}
            </p>
          )
        }
        <p class="meta">
          <time datetime={publishedDate}>{publishedDateLabel}</time>
          {updatedDate && <> &middot; Updated <time datetime={updatedDate}>{updatedDateLabel}</time></>}
        </p>
      </header>
      <LanguageSwitch activeLanguage={entry.data.lang} enUrl={enUrl} zhUrl={zhUrl} />
      <div class="prose">
        <slot />
      </div>
      {
        entry.data.publishedAtExternalUrl && (
          <p class="external">Also published <a href={entry.data.publishedAtExternalUrl} target="_blank">here</a>.</p>
        )
      }
    </article>
  </main>
</BaseLayout>
