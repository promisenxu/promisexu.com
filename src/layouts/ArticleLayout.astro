---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articleJsonLd, buildSeo } from "@/lib/seo";
import { getWritingUrl, type WritingEntry } from "@/lib/content";

type Props = {
  entry: WritingEntry;
};

const { entry } = Astro.props;
const url = getWritingUrl(entry);
const seo = buildSeo({
  title: entry.data.title,
  description: entry.data.description,
  path: url,
  canonical: entry.data.canonicalUrl,
  type: "article"
});
const publishedDate = entry.data.date.toISOString().slice(0, 10);
const updatedDate = entry.data.updated?.toISOString().slice(0, 10);
const jsonLd = [
  articleJsonLd({
    title: entry.data.title,
    description: entry.data.description,
    url: seo.canonical,
    datePublished: entry.data.date,
    dateModified: entry.data.updated,
    lang: entry.data.lang
  })
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  lang={entry.data.lang}
  image={seo.image}
  type="article"
  jsonLd={jsonLd}
>
  <main class="article-shell">
    <article class="prose" lang={entry.data.lang}>
      <p class="eyebrow">{entry.data.category} &middot; {entry.data.lang === "zh" ? "中文" : "English"}</p>
      <h1>{entry.data.title}</h1>
      <p class="dek">{entry.data.description}</p>
      <p class="meta">
        Published <time datetime={publishedDate}>{publishedDate}</time>
        {updatedDate && <> &middot; Updated <time datetime={updatedDate}>{updatedDate}</time></>}
      </p>
      <slot />
      {entry.data.publishedAtExternalUrl && (
        <p class="external">Originally published externally: <a href={entry.data.publishedAtExternalUrl}>source</a></p>
      )}
    </article>
  </main>
</BaseLayout>

<style>
  .article-shell {
    padding: 56px 0;
  }

  .eyebrow,
  .meta,
  .external {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .dek {
    color: var(--color-muted);
    font-size: 1.25rem;
    line-height: 1.5;
  }
</style>
