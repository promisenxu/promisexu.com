---
import SiteNav from "@/components/SiteNav.astro";
import ContentViewFilterIsland from "@/components/ContentViewFilterIsland";
import { serializeJsonLd } from "@/lib/seo";
import "@/styles/global.css";

type Props = {
  title: string;
  description: string;
  canonical: string;
  author?: string;
  alternates?: Array<{ lang: "en" | "zh"; href: string }>;
  lang?: "en" | "zh";
  image?: string;
  type?: "website" | "article";
  jsonLd?: unknown[];
  showContentView?: boolean;
};

const {
  title,
  description,
  canonical,
  author,
  alternates = [],
  lang = "en",
  image,
  type = "website",
  jsonLd = [],
  showContentView = true
} = Astro.props;

const pathname = Astro.url.pathname;
const initialView = pathname.startsWith("/en/")
  ? "en"
  : pathname.startsWith("/zh/")
    ? "zh"
    : "all";
const contentPath = initialView === "all" ? pathname : pathname.slice(3);
const scopedViewHrefs = {
  "/": { all: "/", en: "/en/", zh: "/zh/" },
  "/projects/": { all: "/projects/", en: "/en/projects/", zh: "/zh/projects/" },
  "/about/": { all: "/about/", en: "/en/about/", zh: "/zh/about/" }
} as const;
const viewHrefs =
  scopedViewHrefs[contentPath as keyof typeof scopedViewHrefs] ??
  (contentPath.startsWith("/writing/")
    ? { all: "/writing/", en: "/en/writing/", zh: "/zh/writing/" }
    : { all: pathname, en: "/en/writing/", zh: "/zh/writing/" });
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {author && <meta name="author" content={author} />}
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />
    ))}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    {image && <meta name="twitter:image" content={image} />}
    {jsonLd.map((entry) => (
      <script type="application/ld+json" is:inline set:html={serializeJsonLd(entry)} />
    ))}
  </head>
  <body>
    {
      showContentView && (
        <ContentViewFilterIsland client:only="react" initialView={initialView} interceptLinks={initialView === "all"} />
      )
    }
    <div class="site-shell">
      <SiteNav showContentView={showContentView} initialView={initialView} hrefs={viewHrefs} />
      <div class="site-content">
        <slot />
        <footer class="site-footer">
          <p>&copy; {new Date().getFullYear()} Promise Xu. Writing, projects, and selected work.</p>
        </footer>
      </div>
    </div>
  </body>
</html>
