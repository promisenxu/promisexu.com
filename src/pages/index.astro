---
import ContentViewFilter from "@/components/ContentViewFilter.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import WritingCard from "@/components/WritingCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getHomepageWritings, getProjects } from "@/lib/content";
import { buildSeo, personJsonLd, websiteJsonLd } from "@/lib/seo";

const writings = await getHomepageWritings();
const homepageWritings = {
  all: writings.slice(0, 6),
  en: writings.filter((entry) => entry.data.lang === "en").slice(0, 6),
  zh: writings.filter((entry) => entry.data.lang === "zh").slice(0, 6)
};
const projects = (await getProjects()).slice(0, 3);
const seo = buildSeo({
  title: "Promise Xu",
  description: "A personal publication for writing on growth, marketing, business, culture, art, film, and the web.",
  path: "/"
});
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} jsonLd={[personJsonLd(), websiteJsonLd()]}>
  <ContentViewFilter slot="rail" />

  <main>
    <section class="home-masthead">
      <h1>PROMISE XU</h1>
      <p>Writing and projects across growth, culture, and the web.</p>
    </section>

    {Object.entries(homepageWritings).map(([view, entries]) => {
      const languagePositions = { en: 0, zh: 0 };
      return (
        <section class="writing-stream" aria-label="Selected writing" data-home-view={view}>
          {entries.map((entry) => {
            const position = languagePositions[entry.data.lang]++;
            const variant = position === 0 ? "lead" : position < 3 ? "tile" : "row";
            return <WritingCard entry={entry} variant={variant} />;
          })}
        </section>
      );
    })}

    <section class="home-projects" aria-labelledby="projects-heading">
      <h2 id="projects-heading">Projects</h2>
      <div class="project-list">
        {projects.map((project) => <ProjectCard project={project} compact />)}
      </div>
    </section>
  </main>
</BaseLayout>
