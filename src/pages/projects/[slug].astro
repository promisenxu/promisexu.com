---
import { render } from "astro:content";
import LanguageSwitch from "@/components/LanguageSwitch.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProjectCounterpart, getProjects, getProjectUrl, type ProjectEntry } from "@/lib/content";
import { buildSeo } from "@/lib/seo";
import { site } from "@/lib/site";

type Props = {
  project: ProjectEntry;
};

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: getProjectUrl(project).split("/").filter(Boolean).at(-1) },
    props: { project }
  }));
}

const { project } = Astro.props;
const counterpart = await getProjectCounterpart(project);
const enUrl = project.data.lang === "en" ? getProjectUrl(project) : counterpart && getProjectUrl(counterpart);
const zhUrl = project.data.lang === "zh" ? getProjectUrl(project) : counterpart && getProjectUrl(counterpart);
const alternates = counterpart
  ? [
      { lang: "en" as const, href: new URL(enUrl!, site.url).toString() },
      { lang: "zh" as const, href: new URL(zhUrl!, site.url).toString() }
    ]
  : [];
const seo = buildSeo({
  title: project.data.name,
  description: project.data.description,
  path: getProjectUrl(project)
});
const { Content } = await render(project);
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  alternates={alternates}
  showContentView={false}
>
  <main>
    <section class="page-header page-header--compact">
      <p class="eyebrow">Project</p>
      <h1>{project.data.name}</h1>
      <p>{project.data.description}</p>
    </section>

    <LanguageSwitch activeLanguage={project.data.lang} enUrl={enUrl} zhUrl={zhUrl} />

    <article class="project-detail" lang={project.data.lang}>
      {project.data.image && (
        <img class="project-detail__image" src={project.data.image} alt={`${project.data.name} project preview`} />
      )}
      <div class="project-detail__meta">
        <p><strong>Role</strong> {project.data.role}</p>
        {project.data.status && <p><strong>Status</strong> {project.data.status}</p>}
        {project.data.link && <p><a href={project.data.link}>Visit project</a></p>}
      </div>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
