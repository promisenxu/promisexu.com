---
import ProjectCard from "@/components/ProjectCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProjects } from "@/lib/content";
import { buildSeo } from "@/lib/seo";

const projects = await getProjects();
const views = [
  { key: "all", label: "No projects are available yet." },
  { key: "en", label: "No projects are available in English yet." },
  { key: "zh", label: "No projects are available in Chinese yet." }
] as const;
const emptyViews = views.filter(({ key }) =>
  key === "all" ? projects.length === 0 : !projects.some((project) => project.data.lang === key)
);
const seo = buildSeo({
  title: "Projects",
  description: "Selected project work by Promise Xu.",
  path: "/projects/"
});
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical}>
  <main>
    <section class="page-header">
      <h1>Projects</h1>
      <p>Selected work, shown as visual proof rather than exhaustive case studies.</p>
    </section>
    <section class="project-list" aria-label="Selected work">
      {projects.map((project) => <ProjectCard project={project} />)}
    </section>
    {emptyViews.map(({ key, label }) => (
      <p class="filtered-empty" data-empty-for={key} hidden>{label}</p>
    ))}
  </main>
</BaseLayout>
