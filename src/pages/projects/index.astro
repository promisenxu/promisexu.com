---
import ProjectCard from "@/components/ProjectCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProjects } from "@/lib/content";
import { buildSeo } from "@/lib/seo";

const projects = await getProjects();
const seo = buildSeo({
  title: "Projects",
  description: "Selected project work by Promise Xu.",
  path: "/projects/"
});
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical}>
  <main>
    <section class="page-header">
      <h1>Projects</h1>
      <p>Selected work, shown as visual proof rather than exhaustive case studies.</p>
    </section>
    <section class="project-grid" aria-label="Selected work">
      {projects.map((project) => <ProjectCard project={project} />)}
    </section>
  </main>
</BaseLayout>

<style>
  .page-header {
    padding: 56px 0 24px;
  }

  .page-header h1 {
    margin: 0 0 12px;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.95;
  }

  .page-header p {
    max-width: 62ch;
    margin: 0;
    color: var(--color-muted);
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }
</style>
