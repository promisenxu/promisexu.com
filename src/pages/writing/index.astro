---
import ArchiveControls from "@/components/ArchiveControls.astro";
import ContentViewFilter from "@/components/ContentViewFilter.astro";
import WritingCard from "@/components/WritingCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedWritings } from "@/lib/content";
import { buildSeo, websiteJsonLd } from "@/lib/seo";

const writings = await getPublishedWritings();
const englishTranslationKeys = new Set(
  writings
    .filter((entry) => entry.data.lang === "en" && entry.data.translationKey)
    .map((entry) => entry.data.translationKey)
);
const chineseByTranslationKey = new Map(
  writings
    .filter((entry) => entry.data.lang === "zh" && entry.data.translationKey)
    .map((entry) => [entry.data.translationKey, entry])
);
const allWritings = writings.filter(
  (entry) =>
    entry.data.lang === "en" ||
    !entry.data.translationKey ||
    !englishTranslationKeys.has(entry.data.translationKey)
);
const seo = buildSeo({
  title: "Writing",
  description: "All writing by Promise Xu across English and Chinese.",
  path: "/writing/"
});
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} jsonLd={[websiteJsonLd()]}>
  <ContentViewFilter
    selected="all"
    label="View writing"
    hrefs={{ all: "/writing/", en: "/en/writing/", zh: "/zh/writing/" }}
    slot="rail"
  />

  <main>
    <section class="page-header">
      <h1>Writing</h1>
      <p>Essays, criticism, notes, and published work across English and Chinese.</p>
    </section>
    <ArchiveControls />
    <section aria-label="All writing">
      {allWritings.map((entry) => {
        const chineseCounterpart = entry.data.translationKey
          ? chineseByTranslationKey.get(entry.data.translationKey)
          : undefined;
        return (
          <WritingCard
            entry={entry}
            variant="row"
            alternateUrl={chineseCounterpart ? `/zh/writing/${chineseCounterpart.data.slug}/` : undefined}
            alternateLabel={chineseCounterpart ? "Also in 中文 →" : undefined}
          />
        );
      })}
    </section>
  </main>
</BaseLayout>
